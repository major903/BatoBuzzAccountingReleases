<UserControl x:Class="BatoBuzz.Desktop.Views.ChartOfAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Chart of Accounts" Style="{DynamicResource ViewTitle}"/>
                <TextBlock Text="Create the account groups and posting ledgers your business needs. Customer, supplier, and inventory control accounts remain protected." Style="{DynamicResource ViewSubtitle}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{DynamicResource SectionPanel}">
                <StackPanel>
                    <TextBlock Text="Account Group" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding AccountGroupName}" ToolTip="Account group name" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AccountTypes}" SelectedItem="{Binding AccountType}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Create" Command="{Binding SaveAccountGroupCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Rename Selected" Command="{Binding RenameSelectedAccountGroupCommand}" Style="{DynamicResource SecondaryButton}"/>
                        <Button Content="Activate / Deactivate" Command="{Binding ToggleSelectedAccountGroupActiveCommand}" Style="{DynamicResource SecondaryButton}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{DynamicResource SectionPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="New Ledger" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Text="{Binding LedgerName}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Account Group" Style="{DynamicResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AccountGroups}" SelectedItem="{Binding SelectedAccountGroup}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="4">
                        <TextBlock Text="Type" Style="{DynamicResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding LedgerTypes}" SelectedItem="{Binding LedgerType}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock Text="Code (optional)" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Text="{Binding LedgerCode}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                        <Button Content="Create" Command="{Binding SaveLedgerCommand}" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Update Selected" Command="{Binding UpdateSelectedLedgerCommand}" Style="{DynamicResource SecondaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{DynamicResource SecondaryButton}"/>
                <Button Content="Activate / Deactivate Selected" Command="{Binding ToggleSelectedLedgerActiveCommand}" Style="{DynamicResource SecondaryButton}" Margin="8,0,0,0"/>
            </StackPanel>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Ledgers}" SelectedItem="{Binding SelectedLedger}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Group" Binding="{Binding AccountGroup.Name}" Width="*"/>
                    <DataGridTextColumn Header="Account Type" Binding="{Binding AccountGroup.AccountType}" Width="120"/>
                    <DataGridTextColumn Header="Ledger" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                    <DataGridTextColumn Header="Ledger Type" Binding="{Binding LedgerType}" Width="120"/>
                    <DataGridTextColumn Header="Current Balance" Binding="{Binding CurrentBalance, StringFormat='Rs. {0:N2}'}" Width="140"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
