<UserControl x:Class="BatoBuzz.Desktop.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Padding="22,18" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Customers" Style="{DynamicResource ViewTitle}"/>
                <TextBlock Text="Keep customer contact details and credit limits in one place." Style="{DynamicResource ViewSubtitle}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="+ New Customer" Command="{Binding AddNewCommand}" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="Edit" Command="{Binding EditCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <TextBox Text="{Binding SearchText}" Width="260" Margin="0,0,8,0" ToolTip="Search customers by name"/>
            <Button Content="Search" Command="{Binding SearchCommand}" Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>

        <!-- Customer List -->
        <Border Grid.Row="2" Style="{DynamicResource SectionPanel}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Name" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Name}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Phone" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Phone}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="PAN" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding PanNumber}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="6">
                    <TextBlock Text="Credit Limit" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding CreditLimit}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                    <Button Content="Save" Command="{Binding SaveCommand}" Style="{DynamicResource PrimaryButton}" Margin="0,0,6,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                    <TextBlock Text="Address" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Address}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                    <TextBlock Text="City" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding City}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="3" Margin="0,8,0,0">
                    <TextBlock Text="Email" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Email}" IsEnabled="{Binding IsEditing}"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.ColumnSpan="8" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat='Rs. {0:N2}'}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
