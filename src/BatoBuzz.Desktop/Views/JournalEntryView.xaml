<UserControl x:Class="BatoBuzz.Desktop.Views.JournalEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <Grid MinWidth="1320" MaxWidth="1450" HorizontalAlignment="Left" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Entry No" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding EntryNumber}" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding EntryDate}"/>
                    <TextBlock Text="{Binding EntryDateBs, StringFormat='BS: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Voucher Type" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding VoucherTypes}" SelectedItem="{Binding VoucherType}"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Reference" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding ReferenceNumber}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Narration -->
        <Border Grid.Row="1" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <StackPanel>
                <TextBlock Text="Narration" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                <TextBox Text="{Binding Narration}" Height="40" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Lines -->
        <Grid Grid.Row="2" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Journal Lines" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="DEBITS MUST EQUAL CREDITS" Foreground="{Binding IsBalanced, Converter={StaticResource BoolToBrushConverter}}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="40"/>
                        <DataGridTemplateColumn Header="Ledger Account" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LedgerName}" VerticalAlignment="Center" Padding="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.AvailableLedgers, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              Text="{Binding LedgerName}"
                                              IsEditable="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Narration" Binding="{Binding Narration}" Width="2*"/>
                        <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=N2}" Width="110"/>
                        <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat=N2}" Width="110"/>
                        <DataGridTemplateColumn Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Style="{DynamicResource SecondaryButton}" Padding="4,2" FontSize="10"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Totals -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="+ Add Line" Command="{Binding AddLineCommand}" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left" VerticalAlignment="Top" IsEnabled="{Binding IsDocumentEditable}"/>
                <StackPanel Grid.Column="1">
                    <Grid Margin="0,2">
                        <TextBlock Text="Total Debit:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalDebit, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Total Credit:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalCredit, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Difference:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding Difference, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="New Journal" Command="{Binding NewJournalCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Save Draft" Command="{Binding SaveCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Print" Command="{Binding PrintCommand}" IsEnabled="{Binding CanPrint}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Post Journal" Command="{Binding PostCommand}" IsEnabled="{Binding CanPost}" Style="{DynamicResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
