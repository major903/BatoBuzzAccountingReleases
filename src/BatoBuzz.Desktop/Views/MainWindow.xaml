<Window x:Class="BatoBuzz.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BatoBuzz.Desktop.ViewModels"
        xmlns:views="clr-namespace:BatoBuzz.Desktop.Views"
        mc:Ignorable="d"
        Title="" 
        Icon="/Assets/TransparentTitleIcon.ico"
        Height="760" Width="1180"
        MinHeight="680" MinWidth="1024"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CompanySetupViewModel}">
            <views:CompanySetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChangeCompanyViewModel}">
            <views:ChangeCompanyView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesInvoiceViewModel}">
            <views:SalesInvoiceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierViewModel}">
            <views:SupplierView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchaseBillViewModel}">
            <views:PurchaseBillView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReceiptViewModel}">
            <views:ReceiptView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentViewModel}">
            <views:PaymentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JournalEntryViewModel}">
            <views:JournalEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaxSettingsViewModel}">
            <views:TaxSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PeriodLockSettingsViewModel}">
            <views:PeriodLockSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BankReconciliationViewModel}">
            <views:BankReconciliationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChangePasswordViewModel}">
            <views:ChangePasswordView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CorrectionsViewModel}">
            <views:CorrectionsView/>
        </DataTemplate>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Focusable="False">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          Panel.ZIndex="1"/>
                            </ScrollViewer>
                            
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="0,14,0,0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource ShellHeaderBrush}" Height="52">
            <Grid x:Name="AppTitleBar">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                    <Border Width="34" Height="34" CornerRadius="7" Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                        <TextBlock Text="B" FontSize="19" FontWeight="Bold" Foreground="{DynamicResource WhiteBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="BatoBuzz Accounting" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource WhiteBrush}"/>
                        <TextBlock Text="Sales, purchase, inventory, ledgers and reports" FontSize="11" Foreground="{DynamicResource ShellHeaderMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="2" Background="#203154" CornerRadius="8" Padding="12,7" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CompanyName}" Foreground="{DynamicResource WhiteBrush}" FontWeight="Bold" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UserName}" Foreground="{DynamicResource ShellHeaderMutedBrush}" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentDate}" Foreground="{DynamicResource ShellHeaderMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Menu Bar -->
        <Menu Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}">
            <MenuItem Header="_Dashboard" Command="{Binding ShowDashboardCommand}" IsEnabled="{Binding IsAuthenticated}"/>
            <MenuItem Header="_File">
                <MenuItem Header="_Company Setup" Command="{Binding ShowCompanySetupCommand}" IsEnabled="{Binding IsAuthenticated}"/>
                <MenuItem Header="_Change Company" Command="{Binding ShowChangeCompanyCommand}" IsEnabled="{Binding IsAuthenticated}"/>
                <Separator/>
                <MenuItem Header="_Backup" Command="{Binding BackupCommand}" IsEnabled="{Binding IsAuthenticated}"/>
                <MenuItem Header="_Restore" Command="{Binding RestoreCommand}" IsEnabled="{Binding IsAuthenticated}"/>
                <Separator/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}" IsEnabled="{Binding IsAuthenticated}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Accounting" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Journal Entry" Command="{Binding ShowJournalEntryCommand}"/>
                <MenuItem Header="_Chart of Accounts" Command="{Binding ShowReportCommand}" CommandParameter="Chart of Accounts"/>
                <MenuItem Header="_Day Book" Command="{Binding ShowReportCommand}" CommandParameter="Day Book"/>
                <MenuItem Header="_Trial Balance" Command="{Binding ShowReportCommand}" CommandParameter="Trial Balance"/>
                <MenuItem Header="_Bank Reconciliation" Command="{Binding ShowBankReconciliationCommand}"/>
                <MenuItem Header="_Corrections &amp; Reversals" Command="{Binding ShowCorrectionsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Sales" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Sales Invoice" Command="{Binding ShowSalesInvoiceCommand}"/>
                <MenuItem Header="_Customers" Command="{Binding ShowCustomersCommand}"/>
                <MenuItem Header="_Receipts" Command="{Binding ShowReceiptCommand}"/>
                <MenuItem Header="_Credit Notes" Command="{Binding ShowJournalEntryWithTypeCommand}" CommandParameter="Credit Note"/>
            </MenuItem>
            <MenuItem Header="_Purchase" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Purchase Bill" Command="{Binding ShowPurchaseBillCommand}"/>
                <MenuItem Header="_Suppliers" Command="{Binding ShowSuppliersCommand}"/>
                <MenuItem Header="_Payments" Command="{Binding ShowPaymentCommand}"/>
                <MenuItem Header="_Debit Notes" Command="{Binding ShowJournalEntryWithTypeCommand}" CommandParameter="Debit Note"/>
            </MenuItem>
            <MenuItem Header="_Inventory" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Items" Command="{Binding ShowInventoryCommand}"/>
                <MenuItem Header="_Stock Movement" Command="{Binding ShowInventoryCommand}"/>
                <MenuItem Header="_Stock Adjustment" Command="{Binding ShowInventoryCommand}"/>
                <MenuItem Header="_Warehouses" Command="{Binding ShowInventoryCommand}"/>
            </MenuItem>
            <MenuItem Header="_Reports" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Report Center" Command="{Binding ShowReportsCommand}"/>
                <Separator/>
                <MenuItem Header="_Trial Balance" Command="{Binding ShowReportCommand}" CommandParameter="Trial Balance"/>
                <MenuItem Header="_Profit &amp; Loss" Command="{Binding ShowReportCommand}" CommandParameter="Profit &amp; Loss"/>
                <MenuItem Header="_Balance Sheet" Command="{Binding ShowReportCommand}" CommandParameter="Balance Sheet"/>
                <MenuItem Header="_Cash Flow" Command="{Binding ShowReportCommand}" CommandParameter="Cash Flow"/>
                <MenuItem Header="_General Ledger" Command="{Binding ShowReportCommand}" CommandParameter="General Ledger"/>
            </MenuItem>
            <MenuItem Header="_Settings" IsEnabled="{Binding IsAuthenticated}">
                <MenuItem Header="_Change Password" Command="{Binding ShowChangePasswordCommand}"/>
                <Separator/>
                <MenuItem Header="_Tax Settings" Command="{Binding ShowTaxSettingsCommand}"/>
                <MenuItem Header="_Period Lock" Command="{Binding ShowPeriodLockSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_User Guide" Command="{Binding ShowUserGuideCommand}"/>
                <MenuItem Header="_About" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Content Area -->
        <Grid Grid.Row="2" Margin="18">
            <!-- TabControl visible when Authenticated -->
            <TabControl ItemsSource="{Binding ActiveTabs}"
                        SelectedItem="{Binding SelectedTab}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Background="{DynamicResource SurfaceBrush}">
                <TabControl.Style>
                    <Style TargetType="TabControl">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Style>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="22">
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Button Content="×" 
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}" 
                                    CommandParameter="{Binding}"
                                    FontWeight="Bold"
                                    Width="18" Height="18"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Header}" Value="Dashboard">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding ViewModel}"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- Login View ContentControl visible when NOT Authenticated -->
            <ContentControl Content="{Binding CurrentView}"
                            ClipToBounds="True">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="{DynamicResource SurfaceBrush}">
            <StatusBarItem>
                <TextBlock Text="Ready" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CompanyName}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="v1.0.0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
