<UserControl x:Class="BatoBuzz.Desktop.Views.SalesInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <Grid MinWidth="980" MaxWidth="1480" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Sales Invoice" Style="{DynamicResource ViewTitle}"/>
                    <TextBlock Text="Save a draft while you work, then post only after the customer, lines, and totals are final." Style="{DynamicResource ViewSubtitle}" Margin="0,4,0,14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Saved drafts" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding DraftInvoices}" SelectedItem="{Binding SelectedDraft}" DisplayMemberPath="InvoiceNumber" Width="180" Margin="0,0,8,0"/>
                        <Button Content="Load Draft" Command="{Binding LoadDraftCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Discard Draft" Command="{Binding DiscardDraftCommand}" Style="{DynamicResource SecondaryButton}"/>
                    </StackPanel>
                </StackPanel>
                <Grid Grid.Row="1" IsEnabled="{Binding IsDocumentEditable}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Invoice No" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding InvoiceNumber}" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding InvoiceDate}"/>
                    <TextBlock Text="{Binding InvoiceDateBs, StringFormat='BS: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Due Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding DueDate}"/>
                </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Customer Info -->
        <Border Grid.Row="1" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Customer" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Text="{Binding CustomerName}" ItemsSource="{Binding AvailableCustomers}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reference" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Reference}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="VAT Applicable" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <CheckBox IsChecked="{Binding IsVatApplicable}" Foreground="{DynamicResource TextPrimaryBrush}" Content="Yes"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Line Items -->
        <Grid Grid.Row="2" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Line Items" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="40"/>
                        <DataGridTemplateColumn Header="Item" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedItem.Name}" VerticalAlignment="Center" Padding="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.AvailableItems, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding SelectedItem}"
                                              DisplayMemberPath="Name" TextSearch.TextPath="Name" IsEditable="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Disc%" Binding="{Binding DiscountPercent}" Width="60"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="120" IsReadOnly="True"/>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" Style="{DynamicResource SecondaryButton}" Padding="4,2" FontSize="10"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Totals -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="+ Add Line" Command="{Binding AddLineCommand}" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left" VerticalAlignment="Top" IsEnabled="{Binding IsDocumentEditable}"/>
                <StackPanel Grid.Column="1">
                    <Grid Margin="0,2">
                        <TextBlock Text="Sub Total:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SubTotal, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Discount:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding DiscountAmount, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="VAT:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding VatAmount, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Separator Margin="0,4"/>
                    <Grid Margin="0,2">
                        <TextBlock Text="Total:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="16" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="New Invoice" Command="{Binding NewInvoiceCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Save Draft" Command="{Binding SaveCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Print" Command="{Binding PrintCommand}" IsEnabled="{Binding CanPrint}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Post Invoice" Command="{Binding PostCommand}" IsEnabled="{Binding CanPost}" Style="{DynamicResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
