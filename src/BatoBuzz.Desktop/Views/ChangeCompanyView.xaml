<UserControl x:Class="BatoBuzz.Desktop.Views.ChangeCompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Style="{DynamicResource SectionPanel}" CornerRadius="12" Padding="40" Width="560">
            <StackPanel>
                <TextBlock Text="Change Company" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Select a company to switch to, or create a new one." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding Companies}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding TradingName}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Switch" Style="{DynamicResource SecondaryButton}"
                                            IsEnabled="{Binding CanSwitch}"
                                            Command="{Binding DataContext.SwitchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,12"/>

                <Button Content="+ Create New Company" Command="{Binding CreateNewCommand}" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
