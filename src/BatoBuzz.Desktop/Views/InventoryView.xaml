<UserControl x:Class="BatoBuzz.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Item Name" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding ItemName}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Code" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding ItemCode}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="Cost" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding StandardCost}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="6">
                    <TextBlock Text="Sale Price" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding SalePrice}"/>
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="8" Content="Save Item" Command="{Binding SaveItemCommand}" Style="{DynamicResource PrimaryButton}" VerticalAlignment="Bottom"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                    <TextBlock Text="Reorder Level (optional)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding ReorderLevel}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Movement Item" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Text="{Binding MovementItemName}" ItemsSource="{Binding AvailableItems}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Type" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding MovementTypes}" SelectedItem="{Binding MovementType}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Quantity" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Quantity}"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Unit Cost" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding UnitCost}"/>
                </StackPanel>
                <StackPanel Grid.Column="8">
                    <TextBlock Text="Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding MovementDate}" Width="130"/>
                </StackPanel>
                <Button Grid.Column="10" Content="Post Movement" Command="{Binding RecordMovementCommand}" Style="{DynamicResource PrimaryButton}" VerticalAlignment="Bottom"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="11" Margin="0,8,0,0">
                    <TextBlock Text="Narration / reason" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Narration}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Text="{Binding SearchText}" Width="200" Margin="0,0,8,0"/>
                <Button Content="Search" Command="{Binding SearchCommand}" Style="{DynamicResource SecondaryButton}"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Warehouse" Binding="{Binding Warehouse}" Width="*"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, StringFormat=N2}" Width="*"/>
                    <DataGridTextColumn Header="Avg Cost" Binding="{Binding AverageCost, StringFormat='Rs. {0:N2}'}" Width="*"/>
                    <DataGridTextColumn Header="Value" Binding="{Binding TotalValue, StringFormat='Rs. {0:N2}'}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Low" Binding="{Binding IsLowStock}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
