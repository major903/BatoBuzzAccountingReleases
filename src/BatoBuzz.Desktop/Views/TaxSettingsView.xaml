<UserControl x:Class="BatoBuzz.Desktop.Views.TaxSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tax Settings" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
            TDS (Tax Deducted at Source) rates are not pre-loaded. Official Nepal withholding
            percentages vary by payment type and must be confirmed with your accountant before
            use. Add the rates that apply to your business below, then select one when recording
            a supplier payment.
        </TextBlock>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="+ New Rate" Command="{Binding AddNewCommand}" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="Edit" Command="{Binding EditCommand}" Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Padding="12" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Name" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Text="{Binding Name}" IsEnabled="{Binding IsEditing}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Rate %" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Text="{Binding RatePercent}" IsEnabled="{Binding IsEditing}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Description" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Text="{Binding Description}" IsEnabled="{Binding IsEditing}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom" Margin="12,0,0,0">
                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" IsEnabled="{Binding IsEditing}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                        <Button Content="Save" Command="{Binding SaveCommand}" Style="{DynamicResource PrimaryButton}" Margin="0,0,6,0"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{DynamicResource SecondaryButton}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="8" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rates}" SelectedItem="{Binding SelectedRate}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Rate %" Binding="{Binding RatePercent, StringFormat=N2}" Width="*"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
