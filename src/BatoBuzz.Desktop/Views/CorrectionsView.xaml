<UserControl x:Class="BatoBuzz.Desktop.Views.CorrectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Correction date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding CorrectionDate}" Width="140"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reason (required and retained in the audit trail)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button Grid.Column="4" Content="Refresh" Command="{Binding RefreshCommand}" Style="{DynamicResource SecondaryButton}" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Sales Invoices">
                <DataGrid ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="140"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat='Rs. {0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Correction reason" Binding="{Binding CorrectionReason}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Receipts">
                <DataGrid ItemsSource="{Binding Receipts}" SelectedItem="{Binding SelectedReceipt}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding ReceiptDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Receipt" Binding="{Binding ReceiptNumber}" Width="140"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='Rs. {0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Correction reason" Binding="{Binding CorrectionReason}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Purchase Bills">
                <DataGrid ItemsSource="{Binding Bills}" SelectedItem="{Binding SelectedBill}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding BillDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Bill" Binding="{Binding BillNumber}" Width="140"/>
                        <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat='Rs. {0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Correction reason" Binding="{Binding CorrectionReason}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Payments">
                <DataGrid ItemsSource="{Binding Payments}" SelectedItem="{Binding SelectedPayment}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Payment" Binding="{Binding PaymentNumber}" Width="140"/>
                        <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='Rs. {0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Correction reason" Binding="{Binding CorrectionReason}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Manual Journals">
                <DataGrid ItemsSource="{Binding Journals}" SelectedItem="{Binding SelectedJournal}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding EntryDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Number" Binding="{Binding EntryNumber}" Width="140"/>
                        <DataGridTextColumn Header="Voucher" Binding="{Binding VoucherType}" Width="140"/>
                        <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNumber}" Width="160"/>
                        <DataGridTextColumn Header="Narration" Binding="{Binding Narration}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding TotalDebit, StringFormat='Rs. {0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Reversal reason" Binding="{Binding ReversalReason}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel Invoice" Command="{Binding CancelInvoiceCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Reverse Receipt" Command="{Binding ReverseReceiptCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Cancel Bill" Command="{Binding CancelBillCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Reverse Payment" Command="{Binding ReversePaymentCommand}" Style="{DynamicResource PrimaryButton}"/>
                <Button Content="Reverse Journal" Command="{Binding ReverseJournalCommand}" Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
