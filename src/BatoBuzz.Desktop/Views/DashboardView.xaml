<UserControl x:Class="BatoBuzz.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
    <Grid Width="1280" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Live accounting position for the selected company" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="16,8"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="-7,0,-7,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource KpiCard}" MinHeight="96">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="8,0,0,8"/>
                    <StackPanel Grid.Column="1" Margin="16,14">
                        <TextBlock Text="Cash Balance" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CashBalance, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{DynamicResource KpiCard}" MinHeight="96">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8,0,0,8"/>
                    <StackPanel Grid.Column="1" Margin="16,14">
                        <TextBlock Text="Bank Balance" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding BankBalance, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{DynamicResource KpiCard}" MinHeight="96">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="8,0,0,8"/>
                    <StackPanel Grid.Column="1" Margin="16,14">
                        <TextBlock Text="Sales" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalSalesMonth, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource SuccessBrush}" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="3" Style="{DynamicResource KpiCard}" MinHeight="96">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource WarningBrush}" CornerRadius="8,0,0,8"/>
                    <StackPanel Grid.Column="1" Margin="16,14">
                        <TextBlock Text="Purchases" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalPurchasesMonth, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource WarningBrush}" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource KpiCard}" MinHeight="96">
                <StackPanel Margin="17,14">
                    <TextBlock Text="Receivables" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalReceivables, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding OutstandingInvoices, StringFormat='{}{0} invoices'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource KpiCard}" MinHeight="96">
                <StackPanel Margin="17,14">
                    <TextBlock Text="Payables" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalPayables, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource ErrorBrush}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding OutstandingBills, StringFormat='{}{0} bills'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{DynamicResource KpiCard}" MinHeight="96">
                <StackPanel Margin="17,14">
                    <TextBlock Text="Gross Profit" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="{Binding GrossProfitMonth, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource SuccessBrush}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Current month" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="3" Style="{DynamicResource KpiCard}" MinHeight="96">
                <StackPanel Margin="17,14">
                    <TextBlock Text="Low Stock" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="{Binding LowStockItemsCount}" Foreground="{DynamicResource ErrorBrush}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Needs attention" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Height="Auto" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource SectionPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Daily Work" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <UniformGrid Grid.Row="1" Columns="3" Rows="2" VerticalAlignment="Top">
                        <Button Content="New Sales Invoice" Command="{Binding DataContext.ShowSalesInvoiceCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource PrimaryButton}" Margin="5" Padding="14,10" Height="64"/>
                        <Button Content="New Purchase Bill" Command="{Binding DataContext.ShowPurchaseBillCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource SecondaryButton}" Margin="5" Padding="14,10" Height="64"/>
                        <Button Content="Journal Entry" Command="{Binding DataContext.ShowJournalEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource SecondaryButton}" Margin="5" Padding="14,10" Height="64"/>
                        <Button Content="Receipt" Command="{Binding DataContext.ShowReceiptCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource SecondaryButton}" Margin="5" Padding="14,10" Height="64"/>
                        <Button Content="Payment" Command="{Binding DataContext.ShowPaymentCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource SecondaryButton}" Margin="5" Padding="14,10" Height="64"/>
                        <Button Content="Inventory" Command="{Binding DataContext.ShowInventoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{DynamicResource SecondaryButton}" Margin="5" Padding="14,10" Height="64"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource SectionPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Financial Reports" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <UniformGrid Grid.Row="1" Columns="1" Rows="3" VerticalAlignment="Top">
                        <Button Content="Trial Balance" Command="{Binding DataContext.ShowReportCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Trial Balance" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,10" Padding="14,10" Height="58"/>
                        <Button Content="Profit &amp; Loss" Command="{Binding DataContext.ShowReportCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Profit &amp; Loss" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,10" Padding="14,10" Height="58"/>
                        <Button Content="Balance Sheet" Command="{Binding DataContext.ShowReportCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Balance Sheet" Style="{DynamicResource SecondaryButton}" Padding="14,10" Height="58"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</UserControl>
