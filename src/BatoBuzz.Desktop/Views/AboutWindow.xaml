<Window x:Class="BatoBuzz.Desktop.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About BatoBuzz Accounting"
        Width="510"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}">
    <Border Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" CornerRadius="10"
                        Background="{DynamicResource PrimaryBrush}"
                        VerticalAlignment="Top">
                    <TextBlock Text="B" FontSize="25" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="BatoBuzz Accounting" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VersionText" Margin="0,3,0,0"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="Offline-first accounting for Nepal" Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="0,24,0,0" Padding="16"
                    Background="{DynamicResource PrimarySoftBrush}" CornerRadius="8">
                <TextBlock Text="Manage the day-to-day finances of your business with confidence—whether you are connected to the internet or not."
                           TextWrapping="Wrap" LineHeight="20"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Border>

            <Grid Grid.Row="2" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="WORKFLOWS" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="Sales &amp; purchase" Margin="0,9,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Receipts &amp; payments" Margin="0,5,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Journals &amp; ledgers" Margin="0,5,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="TOOLS" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="Inventory &amp; stock" Margin="0,9,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Reports &amp; tax settings" Margin="0,5,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Backup, restore &amp; updates" Margin="0,5,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,26,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="© 2026 BatoBuzz Technologies Pvt Ltd"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close" IsCancel="True" MinWidth="92"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
