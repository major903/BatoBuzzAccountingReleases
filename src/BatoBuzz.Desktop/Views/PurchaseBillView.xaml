<UserControl x:Class="BatoBuzz.Desktop.Views.PurchaseBillView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <Grid MinWidth="1180">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Bill No" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding BillNumber}" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Supplier Invoice" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding SupplierInvoiceNumber}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Bill Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding BillDate}"/>
                    <TextBlock Text="{Binding BillDateBs, StringFormat='BS: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Due Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding DueDate}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Supplier" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Text="{Binding SupplierName}" ItemsSource="{Binding AvailableSuppliers}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reference" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Text="{Binding Reference}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="VAT Applicable" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <CheckBox IsChecked="{Binding IsVatApplicable}" Foreground="{DynamicResource TextPrimaryBrush}" Content="Yes"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8" IsEnabled="{Binding IsDocumentEditable}">
            <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="40"/>
                    <DataGridTemplateColumn Header="Item" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SelectedItem.Name}" VerticalAlignment="Center" Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableItems, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding SelectedItem}"
                                          DisplayMemberPath="Name" TextSearch.TextPath="Name" IsEditable="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Disc%" Binding="{Binding DiscountPercent}" Width="60"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding NetAmount, StringFormat=N2}" Width="120" IsReadOnly="True"/>
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" Style="{DynamicResource SecondaryButton}" Padding="4,2" FontSize="10"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{DynamicResource SectionPanel}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="+ Add Line" Command="{Binding AddLineCommand}" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left" VerticalAlignment="Top" IsEnabled="{Binding IsDocumentEditable}"/>
                <StackPanel Grid.Column="1">
                    <Grid Margin="0,2">
                        <TextBlock Text="Sub Total:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SubTotal, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Discount:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding DiscountAmount, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="VAT:" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding VatAmount, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Separator Margin="0,4"/>
                    <Grid Margin="0,2">
                        <TextBlock Text="Total:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="16" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="New Bill" Command="{Binding NewBillCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Save Draft" Command="{Binding SaveCommand}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Print" Command="{Binding PrintCommand}" IsEnabled="{Binding CanPrint}" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Post Bill" Command="{Binding PostCommand}" IsEnabled="{Binding CanPost}" Style="{DynamicResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
