<UserControl x:Class="BatoBuzz.Desktop.Views.ReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="1120" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{DynamicResource SectionPanel}" Padding="18"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Receipt Voucher"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Customer money received"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,10"
                            MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="Amount"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding Amount, StringFormat='Rs. {0:N2}', TargetNullValue='Rs. 0.00'}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{DynamicResource SectionPanel}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" IsEnabled="{Binding CanEditDocument}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="Customer" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <ComboBox Text="{Binding CustomerName}" ItemsSource="{Binding AvailableCustomers}" IsEditable="True"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="Date" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <DatePicker Text="{Binding ReceiptDateText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding ReceiptDateBs, StringFormat='BS: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,0,14">
                            <TextBlock Text="Amount" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" IsEnabled="{Binding CanEditDocument}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="Method" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding PaymentMethod}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="Bank / Cash Account" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <TextBox Text="{Binding BankName}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,0,14">
                            <TextBlock Text="Reference" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <TextBox Text="{Binding Reference}"/>
                        </StackPanel>
                    </Grid>

                    <Expander Grid.Row="2" Header="Allocate to specific invoices (optional)" IsEnabled="{Binding CanEditDocument}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Enter amounts only for the invoices this receipt should settle. Leaving every amount blank applies oldest invoices first."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,6"/>
                            <DataGrid ItemsSource="{Binding OpenInvoices}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Invoice" Binding="{Binding DocumentNumber}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DocumentDate, StringFormat=d}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Outstanding" Binding="{Binding BalanceDue, StringFormat='Rs. {0:N2}'}" Width="150" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Apply" Binding="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <StackPanel Grid.Row="3" Margin="0,0,0,16" IsEnabled="{Binding CanEditDocument}">
                        <TextBlock Text="Narration" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Text="{Binding Narration}"
                                 Height="72"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <Border Grid.Row="4"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,0,0"
                            Padding="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="New Receipt"
                                    Command="{Binding NewReceiptCommand}"
                                    Style="{DynamicResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    MinWidth="110"/>
                            <Button Grid.Column="2"
                                    Content="Print"
                                    Command="{Binding PrintCommand}"
                                    IsEnabled="{Binding CanPrint}"
                                    Style="{DynamicResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    MinWidth="100"/>
                            <Button Grid.Column="3"
                                    Content="Save Receipt"
                                    Command="{Binding SaveCommand}"
                                    Style="{DynamicResource PrimaryButton}"
                                    MinWidth="140"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
