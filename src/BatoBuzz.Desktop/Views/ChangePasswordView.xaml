<UserControl x:Class="BatoBuzz.Desktop.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False">
        <Grid Margin="0,0,8,8">
            <Border Width="540"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FocusManager.IsFocusScope="True"
                    Style="{DynamicResource SectionPanel}"
                    Padding="28"
                    FocusManager.FocusedElement="{Binding ElementName=CurrentPasswordBox}">
                <StackPanel>
                    <TextBlock Text="Change Password"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Update the password for your local BatoBuzz account."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="12,9"
                            Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Signed in as: "
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SignedInUserName}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Label Target="{Binding ElementName=CurrentPasswordBox}"
                           Padding="0"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                        <AccessText Text="_Current password"/>
                    </Label>
                    <PasswordBox x:Name="CurrentPasswordBox"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 AutomationProperties.Name="Current password"
                                 AutomationProperties.HelpText="Enter the password you currently use to sign in."
                                 Margin="0,0,0,15"/>

                    <Label Target="{Binding ElementName=NewPasswordBox}"
                           Padding="0"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                        <AccessText Text="_New password"/>
                    </Label>
                    <PasswordBox x:Name="NewPasswordBox"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 AutomationProperties.Name="New password"
                                 AutomationProperties.HelpText="Enter a new password between 8 and 128 characters."
                                 Margin="0,0,0,5"/>
                    <TextBlock Text="Use 8–128 characters and do not reuse your current password."
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                    <Label Target="{Binding ElementName=ConfirmPasswordBox}"
                           Padding="0"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                        <AccessText Text="C_onfirm new password"/>
                    </Label>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 AutomationProperties.Name="Confirm new password"
                                 AutomationProperties.HelpText="Enter the new password again."
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               MinHeight="20"
                               Margin="0,0,0,12"
                               AutomationProperties.Name="Password change status"
                               AutomationProperties.LiveSetting="Assertive">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="_Change Password"
                                Command="{Binding ChangePasswordCommand}"
                                Style="{DynamicResource PrimaryButton}"
                                AutomationProperties.Name="Change password"
                                AutomationProperties.HelpText="Validate the entries and change your password."
                                MinWidth="150"
                                Margin="0,0,8,0"
                                IsDefault="True"/>
                        <Button Content="C_lear"
                                Command="{Binding ClearCommand}"
                                Style="{DynamicResource SecondaryButton}"
                                AutomationProperties.Name="Clear password fields"
                                MinWidth="90"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
