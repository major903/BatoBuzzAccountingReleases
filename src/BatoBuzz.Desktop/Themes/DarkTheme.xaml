<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Soft light accounting theme.
         Resource keys are intentionally unchanged so no view, binding,
         command, route, or application logic needs to be modified. -->
    <Color x:Key="BackgroundColor">#F3F6FA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="InputColor">#FBFCFE</Color>

    <Color x:Key="PrimaryColor">#0F766E</Color>
    <Color x:Key="PrimaryDarkColor">#0B5B55</Color>
    <Color x:Key="PrimaryLightColor">#149388</Color>
    <Color x:Key="PrimarySoftColor">#E4F5F2</Color>
    <Color x:Key="HoverColor">#EFF8F6</Color>
    <Color x:Key="SelectionColor">#D7F0EC</Color>

    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="ShellHeaderColor">#0F172A</Color>
    <Color x:Key="ShellHeaderMutedColor">#CBD5E1</Color>
    <Color x:Key="TextPrimaryColor">#172033</Color>
    <Color x:Key="TextSecondaryColor">#64748B</Color>
    <Color x:Key="TextMutedColor">#94A3B8</Color>
    <Color x:Key="BorderColor">#D7E0EA</Color>

    <Color x:Key="SuccessColor">#15803D</Color>
    <Color x:Key="WarningColor">#C2670A</Color>
    <Color x:Key="ErrorColor">#D14343</Color>
    <Color x:Key="DisabledColor">#A8B3C2</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="InputBrush" Color="{StaticResource InputColor}"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoftColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ShellHeaderBrush" Color="{StaticResource ShellHeaderColor}"/>
    <SolidColorBrush x:Key="ShellHeaderMutedBrush" Color="{StaticResource ShellHeaderMutedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
</ResourceDictionary>
