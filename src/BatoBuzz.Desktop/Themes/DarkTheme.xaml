<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Professional light accounting theme.
         Resource keys are intentionally unchanged so no view, binding,
         command, route, or application logic needs to be modified. -->
    <Color x:Key="BackgroundColor">#F5F7FA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="InputColor">#FBFCFF</Color>

    <Color x:Key="PrimaryColor">#0F766E</Color>
    <Color x:Key="PrimaryDarkColor">#0F4E49</Color>
    <Color x:Key="PrimaryLightColor">#0B6B63</Color>
    <Color x:Key="PrimarySoftColor">#DDF7F4</Color>
    <Color x:Key="HoverColor">#EAF7F4</Color>
    <Color x:Key="SelectionColor">#CFF3EE</Color>

    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="ShellHeaderColor">#14213D</Color>
    <Color x:Key="ShellHeaderMutedColor">#D9E2F2</Color>
    <Color x:Key="TextPrimaryColor">#172033</Color>
    <Color x:Key="TextSecondaryColor">#596579</Color>
    <Color x:Key="TextMutedColor">#7B879A</Color>
    <Color x:Key="BorderColor">#9CA3AF</Color>

    <Color x:Key="SuccessColor">#15803D</Color>
    <Color x:Key="WarningColor">#B45309</Color>
    <Color x:Key="ErrorColor">#C24141</Color>
    <Color x:Key="DisabledColor">#A7B0BF</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="InputBrush" Color="{StaticResource InputColor}"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoftColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ShellHeaderBrush" Color="{StaticResource ShellHeaderColor}"/>
    <SolidColorBrush x:Key="ShellHeaderMutedBrush" Color="{StaticResource ShellHeaderMutedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
</ResourceDictionary>
